{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "lib/**/*.ts",
    "constants/**/*.ts",
    "scripts/**/*.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "constants/**/*.ts"
  ],
  "ignoreDependencies": [
    "expo-*",
    "@react-navigation/*"
  ],
  "ignoreBinaries": [
    "python",
    "maestro"
  ],
  "ignoreExportsUsedInFile": true
}
