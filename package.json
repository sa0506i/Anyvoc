{
  "name": "anyvoc",
  "version": "0.0.1",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas-build-pre-install": "mkdir -p .expo/web",
    "build:freq": "tsx scripts/build-freq.ts",
    "build:norms": "tsx scripts/build-norms.ts",
    "build:aoa-llm": "tsx scripts/build-aoa-llm.ts",
    "build:gold": "tsx scripts/build-gold.ts",
    "build:gold-llm": "tsx scripts/build-gold-llm.ts",
    "build:export-features": "tsx scripts/export-features.ts",
    "calibrate": "python scripts/calibrate-model.py",
    "test": "tsc --noEmit && jest --coverage",
    "test:all": "tsc --noEmit && jest && maestro test .maestro/",
    "test:e2e": "maestro test .maestro/",
    "test:e2e:single": "maestro test",
    "validate:en-cefrj": "tsx scripts/validate-words-cefr-en.ts",
    "validate:gold-all": "tsx scripts/validate-gold-all.ts",
    "try:pipeline": "tsx --tsconfig scripts/tsconfig.pipeline.json scripts/try-pipeline.ts",
    "pipeline:csv": "tsx scripts/pipeline-to-csv.ts",
    "corpus:check": "tsx scripts/check-corpus-urls.ts",
    "sweeps:compare": "tsx scripts/compare-sweeps.ts",
    "lint": "eslint lib/ app/ components/ hooks/ constants/",
    "lint:fix": "eslint --fix lib/ app/ components/ hooks/ constants/",
    "format": "prettier --write \"lib/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"constants/**/*.{ts,tsx}\" \"backend/**/*.js\"",
    "format:check": "prettier --check \"lib/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\" \"components/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"constants/**/*.{ts,tsx}\" \"backend/**/*.js\"",
    "prepare": "husky",
    "test:coverage": "jest --coverage",
    "check:dead-code": "knip --no-config-hints",
    "check:security": "npm audit --audit-level=moderate",
    "check:drift": "npm run check:dead-code && npm run check:security && npm run test:coverage"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@infinitered/react-native-mlkit-text-recognition": "^5.0.1",
    "@mozilla/readability": "^0.6.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@supabase/supabase-js": "^2.103.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-share-intent": "~5.1.1",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "fastest-levenshtein": "^1.0.16",
    "franc-min": "^6.2.0",
    "linkedom": "^0.18.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.8.2",
    "tar": "^7.5.13",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.1",
    "xlsx": "^0.18.5"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 50",
      "prettier --check"
    ],
    "backend/**/*.js": [
      "prettier --check"
    ]
  },
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": [
          "@react-native-google-signin/google-signin"
        ]
      }
    }
  }
}
