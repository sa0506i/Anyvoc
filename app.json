{
  "expo": {
    "name": "Anyvoc",
    "slug": "Anyvoc",
    "version": "0.0.1",
    "scheme": "anyvoc",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anyvoc.app",
      "buildNumber": "24",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A8FE0",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.Anyvoc"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-image-picker",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 1
          },
          "iosExtensionName": "ShareExtension"
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "b7c84c6d-4ba8-4481-b92f-bdc250760248"
      },
      "backendApiUrl": "https://anyvoc-backend.fly.dev/api/chat",
      "supabaseUrl": "https://jnxfmzicstzoevijdcrf.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpueGZtemljc3R6b2V2aWpkY3JmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYxNjM5NDMsImV4cCI6MjA5MTczOTk0M30.ZVJDa9QcYJF-2xwXNaoFHjTqclo0bctvkApbbUY3yOc",
      "googleWebClientId": "354874545998-qcr7mjc8l93tudeit8smabr10gtbnen6.apps.googleusercontent.com",
      "googleIosClientId": "354874545998-ubl85hv4t0qo5dq6g4jmfsl0ef9ceaiv.apps.googleusercontent.com"
    }
  }
}
