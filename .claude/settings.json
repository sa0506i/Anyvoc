{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "ask": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git push *)",
      "Bash(git merge)",
      "Bash(git merge:*)",
      "Bash(git merge *)",
      "Bash(git branch -d:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch --delete:*)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete *)"
    ]
  }
}
