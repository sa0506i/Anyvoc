{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote",
    "requireCommit": true    //Add this
  },
  "build": {
    "development": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "EXPO_IMAGE_UTILS_NO_SHARP": "1",
        "EXPO_NO_CACHE": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_IMAGE_UTILS_NO_SHARP": "1",
        "EXPO_NO_CACHE": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_IMAGE_UTILS_NO_SHARP": "1",
        "EXPO_NO_CACHE": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}