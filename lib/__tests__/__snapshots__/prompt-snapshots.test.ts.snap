  { "original": "att springa", "translation": "laufen", "level": "", "type": "verb", "source_cat": "bare", "source_forms": ["sprang"] },
  { "original": "stor", "translation": "klein", "level": "", "type": "adjective", "source_cat": "bare", "source_forms": ["stora"] },
  { "original": "hur som helst", "translation": "im Grunde genommen", "level": "", "type": "phrase", "source_cat": "bare", "source_forms": ["hur som helst"] }
]"
`;

